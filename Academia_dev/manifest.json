{
  "id": "/",
  "name": "Academia — Dashboard Académico",
  "short_name": "Academia",
  "description": "Organiza tu semestre universitario: calificaciones, tareas, notas, pomodoro y más.",
  "start_url": "/index.html?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0a0a0f",
  "theme_color": "#7c6aff",
  "orientation": "any",
  "lang": "es",
  "dir": "ltr",
  "categories": ["education", "productivity", "utilities"],
  "prefer_related_applications": false,

  "icons": [
    {
      "src": "assets/icons/icon-32.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icons/icon-180.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "assets/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "assets/screenshots/screen-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard principal"
    },
    {
      "src": "assets/screenshots/screen-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Vista móvil"
    }
  ],

  "shortcuts": [
    {
      "name": "Nueva Tarea",
      "short_name": "Tarea",
      "description": "Agrega una tarea rápidamente",
      "url": "/index.html?page=tareas&action=new",
      "icons": [{ "src": "assets/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Pomodoro",
      "short_name": "Pomodoro",
      "description": "Inicia una sesión de estudio",
      "url": "/index.html?page=pomodoro",
      "icons": [{ "src": "assets/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Calificaciones",
      "short_name": "Notas",
      "description": "Ver mis calificaciones",
      "url": "/index.html?page=calificaciones",
      "icons": [{ "src": "assets/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],

  "widgets": [
    {
      "name": "Tareas pendientes",
      "short_name": "Tareas",
      "description": "Muestra tus tareas pendientes del día",
      "tag": "tareas-widget",
      "ms_ac_template": "widgets/tareas-template.json",
      "data": "widgets/tareas-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "assets/screenshots/widget-tareas.png",
          "sizes": "400x200",
          "label": "Widget de tareas"
        }
      ],
      "icons": [
        {
          "src": "assets/icons/icon-192.png",
          "sizes": "192x192"
        }
      ],
      "auth": true,
      "update": 3600
    }
  ],

  "share_target": {
    "action": "/index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "handle_links": "preferred",

  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "edge_side_panel": {
    "preferred_width": 400
  }
}
